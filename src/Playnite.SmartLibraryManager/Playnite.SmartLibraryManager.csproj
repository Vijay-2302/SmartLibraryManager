<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net462</TargetFramework>
		<UseWPF>true</UseWPF>
		<LangVersion>latest</LangVersion>
		<Nullable>disable</Nullable>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="PlayniteSDK" Version="6.16.0" />
	</ItemGroup>

	<Target Name="CopyToPlayniteExtensions" AfterTargets="Build">
		<MakeDir Directories="C:\Users\vijay\AppData\Roaming\Playnite\Extensions\SmartLibraryManager" />

		<Copy
			SourceFiles="$(TargetDir)$(TargetFileName)"
			DestinationFolder="C:\Users\vijay\AppData\Roaming\Playnite\Extensions\SmartLibraryManager"
			SkipUnchangedFiles="true" />

		<Copy
			SourceFiles="extension.yaml"
			DestinationFolder="C:\Users\vijay\AppData\Roaming\Playnite\Extensions\SmartLibraryManager"
			SkipUnchangedFiles="true" />
	</Target>

</Project>
